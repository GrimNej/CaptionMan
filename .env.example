# Provider
AI_PROVIDER=mock
OFFICIAL_MODE=false
MODEL_ROUTING_MODE=champion
CHAMPION_ROUTE=fireworks_kimi_glm
GEMMA_USAGE_MODE=off
REQUIRE_GEMMA_FOR_SUBMISSION=false

# Direct provider route
FIREWORKS_API_KEY=
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
EMBEDDED_FIREWORKS_KEY_PATH=/app/.captionman/final_fireworks_key
VISION_MODEL=accounts/fireworks/models/kimi-k2p6
TEXT_MODEL=accounts/fireworks/models/glm-5p2
DEFAULT_VISION_MODEL=accounts/fireworks/models/kimi-k2p6
DEFAULT_TEXT_MODEL=accounts/fireworks/models/glm-5p2
JUDGE_MODEL=accounts/fireworks/models/glm-5p2
REPAIR_MODEL=
GEMMA_MODEL=accounts/fireworks/models/gemma-4-31b-it
ENABLE_GEMMA_COURT=false
FIREWORKS_DOCTOR_LIVE_CHECK=true
FIREWORKS_MAX_OUTPUT_TOKENS=420
FIREWORKS_TEMPERATURE=0.2

# Private proxy route
PROXY_BASE_URL=
PROXY_TOKEN=
PROXY_HEALTH_PATH=/health
PROXY_CAPTION_PATH=/captionman/infer
PROXY_REPAIR_PATH=/captionman/repair
PROXY_DOCTOR_LIVE_CHECK=true

# Pipeline
PIPELINE_MODE=balanced
NUM_FRAMES=6
MIN_FRAMES=4
MAX_FRAMES=8
SCENE_THRESHOLD=0.30
FRAME_MAX_WIDTH=768
FRAME_JPEG_QUALITY=82
FRAME_DEDUPE_HAMMING_THRESHOLD=6
CAPTION_CANDIDATES_PER_STYLE=1
ENABLE_SELF_REPAIR=true
MAX_REPAIR_ATTEMPTS_PER_STYLE=1
MAX_VIDEO_SECONDS=130
MAX_SECONDS_PER_VIDEO=120
MAX_TOTAL_SECONDS=900
MAX_MODEL_CALLS_PER_VIDEO=6
REQUEST_TIMEOUT_SECONDS=120
MAX_RETRIES=3
STYLE_CONCURRENCY=2
RUN_CONCURRENCY=1

# Download safety
MAX_REDIRECTS=3
MAX_DOWNLOAD_MB=250
DOWNLOAD_TIMEOUT_SECONDS=60

# Demo API
DATA_DIR=.data
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
